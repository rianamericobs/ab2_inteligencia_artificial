    {
      "id": "R01",
      "name": "VERMELHO — Saturação crítica",
      "priority": 20,
      "description": "SpO2 < 90% — risco iminente de vida",
      "condition_operator": "AND",
      "cf": 1.0,
      "conditions": [
        {
          "attribute": "saturacao_o2",
          "operator": "<",
          "value": "90"
        }
      ],
      "conclusion": {
        "attribute": "classificacao_risco",
        "value": "VERMELHO — Emergência (atendimento imediato)",
        "cf": 1.0
      }
    },
    {
      "id": "R02",
      "name": "VERMELHO — Crise hipertensiva grave",
      "priority": 20,
      "description": "PAS > 180 + alteração de consciência — emergência hipertensiva",
      "condition_operator": "AND",
      "cf": 1.0,
      "conditions": [
        {
          "attribute": "pressao_sistolica",
          "operator": ">",
          "value": "180"
        },
        {
          "attribute": "nivel_consciencia",
          "operator": "!=",
          "value": "alerta"
        }
      ],
      "conclusion": {
        "attribute": "classificacao_risco",
        "value": "VERMELHO — Emergência (atendimento imediato)",
        "cf": 1.0
      }
    },
